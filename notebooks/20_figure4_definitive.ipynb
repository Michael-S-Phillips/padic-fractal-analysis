    "print(f'  s₀ = {s_0:.6f},  |s| < s₀: {abs(s) < s_0}')\n",
    "print()\n",
    "print('Embedding geometry:')\n",
    "print(f'  Points embedded: {len(padic_points)}')\n",
    "print(f'  NN distance uniform: {np.isclose(nn.std(), 0, atol=1e-8)} (std={nn.std():.2e})')\n",
    "print(f'  X span: {padic_points[:,0].max()-padic_points[:,0].min():.4f}')\n",
    "print(f'  Y span: {padic_points[:,1].max()-padic_points[:,1].min():.4f}')\n",
    "print()\n",
    "print('Source image:')\n",
    "print(f'  Size: {source_image.shape}')\n",
    "print(f'  Foreground: {int(fg_mask.sum())} pixels ({100*fg_mask.mean():.1f}%)')\n",
    "print(f'  Background: {int(bg_mask.sum())} pixels ({100*bg_mask.mean():.1f}%)')\n",
    "print()\n",
    "print('Open questions for next session:')\n",
    "print('  1. Does the coordinate mapping (i,j)→p-adic match what the paper specifies exactly?')\n",
    "print('     The interleaving order (j-first vs i-first) affects which digit is readable')\n",
    "print('     in the Sierpinski space, but not the triangle geometry.')\n",
    "print('  2. The paper uses a specific digit image (not MNIST). If we had that exact image,')\n",
    "print('     the reproduction would be pixel-perfect.')\n",
    "print('  3. Connect the p-adic embedding to the terrain analysis pipeline:')\n",
    "print('     embed terrain patches (not digits) in Sierpinski space.')"
   ]
